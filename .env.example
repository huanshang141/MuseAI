APP_NAME=MuseAI
APP_ENV=development
DEBUG=true
ALLOW_INSECURE_DEV_DEFAULTS=true

DATABASE_URL=postgresql+asyncpg://museai:museai123@localhost:5432/museai
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o-mini

EMBEDDING_PROVIDER=ollama
EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_OLLAMA_MODEL=nomic-embed-text

ELASTICSEARCH_INDEX=museai_chunks_v1
EMBEDDING_DIMS=1536

# Rerank service configuration
# Supported providers: openai, cohere, custom
RERANK_PROVIDER=openai
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=rerank-v1
RERANK_TOP_N=5

# Admin configuration (comma-separated list of admin email addresses)
ADMIN_EMAILS=
