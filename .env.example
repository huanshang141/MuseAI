APP_NAME=MuseAI
APP_ENV=development
DEBUG=true
# SECURITY: Set to false by default. Only set to true in local development.
# When false, JWT_SECRET and LLM_API_KEY must be explicitly configured.
ALLOW_INSECURE_DEV_DEFAULTS=false
# Set to false to disable rate limiting (e.g., for load testing)
RATE_LIMIT_ENABLED=true

# SECURITY: Replace CHANGE_ME_STRONG_PASSWORD with a strong password before deployment.
# Never use default credentials in production.
DATABASE_URL=postgresql+asyncpg://museai:CHANGE_ME_STRONG_PASSWORD@localhost:5432/museai
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

# SECURITY: JWT_SECRET must be at least 32 characters in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com/v1
# SECURITY: LLM_API_KEY is required in production.
LLM_API_KEY=
# Backward-compatible fallback model. Ordinary guide calls use LLM_TOUR_MODEL.
LLM_MODEL=deepseek-v4-flash
# Fast default for tour chat / RAG query rewriting / streaming guide answers.
LLM_TOUR_MODEL=deepseek-v4-flash
# Stronger model for generated reports and research-style summarization tasks.
LLM_REPORT_MODEL=deepseek-v4-pro
LLM_HEADERS={"User-Agent": "curl/8.5.0"}
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=800
LLM_ENABLE_THINKING=false

# Supported providers: ollama, openai
EMBEDDING_PROVIDER=ollama
# Ollama embedding settings (used when EMBEDDING_PROVIDER=ollama)
EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_OLLAMA_MODEL=nomic-embed-text
# OpenAI-compatible embedding settings (used when EMBEDDING_PROVIDER=openai)
# Works with SiliconFlow, OpenAI, and other OpenAI-compatible APIs
EMBEDDING_OPENAI_BASE_URL=
EMBEDDING_OPENAI_API_KEY=
EMBEDDING_OPENAI_MODEL=

ELASTICSEARCH_INDEX=museai_chunks_v1
EMBEDDING_DIMS=1536

# Rerank service configuration
# Supported providers: siliconflow, openai, cohere, custom, mock
# Use mock to disable real rerank calls in local/test environments; do not leave RERANK_PROVIDER empty.
# SECURITY: RERANK_API_KEY is required for real providers in production.
RERANK_PROVIDER=mock
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=rerank-v1
RERANK_TOP_N=10
RERANK_ABSOLUTE_THRESHOLD=0.25
RERANK_RELATIVE_GAP=0.25
RERANK_MIN_DOCS=1
RERANK_MAX_DOCS=8

# Retrieval and chunk merge settings
RETRIEVAL_TOP_K=15
CHUNK_MERGE_ENABLED=true
CHUNK_MERGE_MAX_LEVEL=1
CHUNK_MERGE_MAX_PARENTS=3

# CORS configuration - comma-separated origins or "*" for development
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Logging settings
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FORMAT=json

# Admin configuration (comma-separated list of admin email addresses)
ADMIN_EMAILS=

# TTS service configuration
TTS_ENABLED=false
TTS_PROVIDER=xiaomi
TTS_BASE_URL=https://api.xiaomimimo.com/v1
TTS_API_KEY=
TTS_MODEL=mimo-v2.5-tts
TTS_DEFAULT_VOICE=冰糖
TTS_TIMEOUT=30.0
TTS_VOICE_DESIGN_MODEL=mimo-v2.5-tts-voicedesign

# Trusted proxy configuration.
# Keep empty for local/direct access. Set to comma-separated reverse proxy or
# load balancer IPs only when the backend is deployed behind them and should
# trust X-Forwarded-For, for example: TRUSTED_PROXIES=10.0.0.5,10.0.0.6
TRUSTED_PROXIES=
