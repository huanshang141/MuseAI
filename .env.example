APP_NAME=MuseAI
APP_ENV=development
DEBUG=true
# SECURITY: Set to false by default. Only set to true in local development.
# When false, JWT_SECRET and LLM_API_KEY must be explicitly configured.
ALLOW_INSECURE_DEV_DEFAULTS=false

# SECURITY: Replace CHANGE_ME_STRONG_PASSWORD with a strong password before deployment.
# Never use default credentials in production.
DATABASE_URL=postgresql+asyncpg://museai:CHANGE_ME_STRONG_PASSWORD@localhost:5432/museai
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

# SECURITY: JWT_SECRET must be at least 32 characters in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
# SECURITY: LLM_API_KEY is required in production.
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

EMBEDDING_PROVIDER=ollama
EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_OLLAMA_MODEL=nomic-embed-text

ELASTICSEARCH_INDEX=museai_chunks_v1
EMBEDDING_DIMS=1536

# Rerank service configuration
# Supported providers: openai, cohere, custom
# SECURITY: RERANK_API_KEY is required when RERANK_PROVIDER is set in production.
RERANK_PROVIDER=openai
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=rerank-v1
RERANK_TOP_N=5

# Admin configuration (comma-separated list of admin email addresses)
ADMIN_EMAILS=
